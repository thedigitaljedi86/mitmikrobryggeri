# Mit Mikrobryggeri — miljøvariabler (kopiér til .env, hold .env UDEN for git)

# ── Kerne ──
SESSION_SECRET=skift-mig-til-en-lang-tilfaeldig-streng
# Platform-admins seedes ved opstart: email:kode,email:kode
ADMIN_USERS=admin@mitbryggeri.dk:skift-mig
# SQLite-fil (WAL). Backup skal tage .db + -wal + -shm eller bruge .backup
DATABASE_PATH=data/mit-mikrobryggeri.db
# Sæt 1 for at indlæse demo-data (Bryghuset Enghave). Auto i udvikling.
SEED_DEMO=1

# ── Domæne ──
ROOT_DOMAIN=mitbryggeri.dk
# Fuld rod-URL til email- og PSP-links (bemærk: IKKE prefixet NEXT_PUBLIC_)
PUBLIC_BASE_URL=http://localhost:3000

# ── Email (Resend) ──
RESEND_API_KEY=
EMAIL_FROM=Mit Mikrobryggeri <no-reply@mitbryggeri.dk>

# ── Betaling: platform-abonnement (Stripe) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=

# ── Cron (bearer-token til /api/cron/*) ──
CRON_SECRET=

# ── Alderskontrol (åbent spørgsmål: MitID-broker, CLAUDE.md §8) ──
# MITID_BROKER=criipto
# MITID_CLIENT_ID=
# MITID_CLIENT_SECRET=
